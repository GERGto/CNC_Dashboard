[Unit]
Description=CNC Dashboard MediaMTX
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=dietpi
Group=dietpi
WorkingDirectory=/opt/cnc-dashboard/backend
ExecStart=/usr/local/bin/mediamtx /opt/cnc-dashboard/backend/mediamtx.yml
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
